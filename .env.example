# =============================================================================
# Environment Variables — Cresora ROI Calculator
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For production (Vercel): set these in Project Settings > Environment Variables.
# Never commit real values. Each environment (dev/preview/production) should
# have its own DATABASE_URL and BETTER_AUTH_SECRET.
# =============================================================================

# Database — Neon serverless Postgres connection string
# Get yours at https://neon.tech — create separate branches for dev/preview/prod
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Better Auth — Secret key for signing tokens
# Generate with: openssl rand -base64 32
# MUST be unique per environment. Never reuse between dev and prod.
BETTER_AUTH_SECRET=your-better-auth-secret-here

# Better Auth — Base URL for your app
# Vercel sets this automatically in production. Only needed for local dev.
BETTER_AUTH_URL=http://localhost:3000

# Resend — Transactional email service
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Email From — Sender address for transactional emails
# Use "onboarding@resend.dev" for local dev (no domain verification needed).
# Set per Vercel environment (preview, production) with your verified domain.
EMAIL_FROM=onboarding@resend.dev

# =============================================================================
# Docker Development
# =============================================================================
# When using `docker compose up`, the above variables are pre-configured in
# docker-compose.yml. You only need to set RESEND_API_KEY and EMAIL_FROM
# if you want real email delivery in Docker:
#
#   RESEND_API_KEY=re_your_key EMAIL_FROM=you@domain.com docker compose up
#
# The local Postgres is available at: postgresql://postgres:postgres@localhost:5432/cresora
# Migrations run automatically before the app starts.
