# Docker Environment Variables
# Copy this file to .env for use with docker compose:
#   cp .env.docker.example .env
#
# docker compose automatically loads .env from the project root.

# Database — used by the local Postgres container
DATABASE_URL=postgresql://postgres:postgres@db:5432/cresora

# Better Auth — secret key for signing tokens (generate a real one for production)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Better Auth — base URL for your app
BETTER_AUTH_URL=http://localhost:3000

# Resend — transactional email service (get your key at https://resend.com)
RESEND_API_KEY=re_your_api_key_here

# Email From — sender address for transactional emails
EMAIL_FROM=onboarding@resend.dev
